.model small
.stack 100h
.data
arr db 5 dup(?)
msg db 'Enter 5 numbers:$'
msg2 db 0Dh,0Ah,'Reverse order:$'

.code
main proc
    mov ax, @data
    mov ds, ax

    ; Prompt
    mov dx, offset msg
    mov ah, 9
    int 21h

    ; Input
    mov cx, 5
    mov si, offset arr
input_loop:
    mov ah, 1
    int 21h
    sub al, '0'
    mov [si], al
    inc si
    loop input_loop

    ; Print reverse
    mov dx, offset msg2
    mov ah, 9
    int 21h

    mov cx, 5
    mov si, offset arr+4
print_loop:
    mov dl, [si]
    add dl, '0'
    mov ah, 2
    int 21h
    dec si
    loop print_loop

    mov ah, 4Ch
    int 21h
main endp
end main
