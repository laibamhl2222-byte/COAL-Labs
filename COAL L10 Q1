.model small
.stack 100h
.data
arr db 5 dup(?)        ; array of 5 elements
sum dw 0
msg1 db 'Enter 5 numbers:$'
msg2 db 0Dh,0Ah,'Sum = $'

.code
main proc
    mov ax, @data
    mov ds, ax

    ; Prompt
    mov dx, offset msg1
    mov ah, 9
    int 21h

    ; Input 5 numbers
    mov cx, 5
    mov si, offset arr
input_loop:
    mov ah, 1
    int 21h
    sub al, '0'        ; convert ASCII to number
    mov [si], al
    inc si
    loop input_loop

    ; Calculate sum
    mov cx, 5
    mov si, offset arr
    xor ax, ax
sum_loop:
    add al, [si]
    inc si
    loop sum_loop
    mov sum, ax

    ; Print result
    mov dx, offset msg2
    mov ah, 9
    int 21h

    mov ax, sum
    add ax, '0'
    mov dl, al
    mov ah, 2
    int 21h

    mov ah, 4Ch
    int 21h
main endp
end main
