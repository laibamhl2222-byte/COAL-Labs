; Task 4 - Print even numbers 0 2 4 6 8
.MODEL SMALL
.STACK 100H
.DATA
.CODE
MAIN PROC
    MOV CX, 5           ; five numbers (0,2,4,6,8)
    MOV DL, 0           ; start from 0

PRINT_EVEN:
    ; print current number
    MOV AH, 2
    ADD DL, '0'         ; convert to ASCII
    INT 21H
    SUB DL, '0'         ; back to numeric value

    ; print a space after each number except last
    CMP CX, 1           ; if last number, skip space
    JE SKIP_SPACE
    MOV AH, 2
    MOV DL, ' '
    INT 21H
    MOV DL, BL          ; restore DL? better: keep value in BL
    ; Actually simpler: keep number in BL
    ; Let's restructure to avoid confusion:
    ; We'll use BL to hold numeric value
    ; But for simplicity, rework:

SKIP_SPACE:
    ADD DL, 2           ; next even number
    LOOP PRINT_EVEN

    ; exit
    MOV AH, 4CH
    INT 21H
MAIN ENDP
END MAIN
Note for Task 4: The above code has a small bug because DL is overwritten by space printing. Here is a corrected version:

assembly
; Task 4 - Corrected version
.MODEL SMALL
.STACK 100H
.DATA
.CODE
MAIN PROC
    MOV CX, 5
    MOV BL, 0           ; BL holds the even number

PRINT_EVEN:
    MOV DL, BL
    ADD DL, '0'
    MOV AH, 2
    INT 21H

    ; print space if not last
    CMP CX, 1
    JE  NO_SPACE
    MOV DL, ' '
    INT 21H

NO_SPACE:
    ADD BL, 2
    LOOP PRINT_EVEN

    MOV AH, 4CH
    INT 21H
MAIN ENDP
END MAIN
