.model small
.stack 100h
.data
arr db 5 dup(?)
count db 0
msg db 'Enter 5 numbers:$'
msg2 db 0Dh,0Ah,'Even count = $'

.code
main proc
    mov ax, @data
    mov ds, ax

    ; Prompt
    mov dx, offset msg
    mov ah, 9
    int 21h

    ; Input
    mov cx, 5
    mov si, offset arr
input_loop:
    mov ah, 1
    int 21h
    sub al, '0'
    mov [si], al
    inc si
    loop input_loop

    ; Count evens
    mov cx, 5
    mov si, offset arr
    xor bl, bl
count_loop:
    mov al, [si]
    and al, 1
    jnz not_even
    inc bl
not_even:
    inc si
    loop count_loop
    mov count, bl

    ; Print result
    mov dx, offset msg2
    mov ah, 9
    int 21h

    mov dl, count
    add dl, '0'
    mov ah, 2
    int 21h

    mov ah, 4Ch
    int 21h
main endp
end main
