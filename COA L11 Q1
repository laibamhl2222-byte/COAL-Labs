.model small
.stack 100h
.data
str db 'HELLO$',0   ; string ending with $

.code
main proc
    mov ax, @data
    mov ds, ax

    mov si, offset str   ; point to string
    mov cx, 0            ; counter = 0

count_loop:
    mov al, [si]         ; get character
    cmp al, '$'          ; end of string?
    je done_count
    push ax              ; push character onto stack
    inc cx               ; increase counter
    inc si               ; move to next character
    jmp count_loop

done_count:
    ; CX now has number of characters
    ; For beginners, just stop here
    mov ah, 4Ch
    int 21h
main endp
end main
